# ============================================
# SERVER ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# ============================================
# DATABASE
# ============================================
DATABASE_URL="mysql://root:password@localhost:3306/password_checker"

# ============================================
# JWT
# ============================================
JWT_SECRET="your-access-token-secret-min-32-characters"
JWT_REFRESH_SECRET="your-refresh-token-secret-min-32-characters"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# BCRYPT
# ============================================
BCRYPT_ROUNDS=12

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# ACCOUNT SECURITY
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=1800000

# ============================================
# DOCKER (optional overrides)
# ============================================
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=password_checker
# MYSQL_USER=app_user
# MYSQL_PASSWORD=app_password
# MYSQL_PORT=3306
# SERVER_PORT=3000
# CLIENT_PORT=80
